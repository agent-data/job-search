#!/usr/bin/env python3
"""T3.2-only host-capability shim for exact-model migration evals.

This is not a scheduler emulator. It exposes only the deterministic model facts and
migration-stage effects needed to drive v1 resolution, free preflight, a disabled
test-job canary, cleanup, and rollback-cutoff evidence. It never touches a real host
model roster, scheduler, network, or agent-data account.
"""

import base64
import json
import os
import pathlib
import re
import subprocess
import sys
import tempfile
from datetime import datetime, timedelta, timezone


SCENARIO = os.environ.get("JOBSEARCH_TEST_HOST_SCENARIO", "happy")
LOG_PATH = os.environ.get("JOBSEARCH_TEST_HOST_LOG")
STATE_PATH = os.environ.get("JOBSEARCH_TEST_HOST_STATE")
ROSTER = {
    "fast": "fake-fast-001",
    "balanced": "fake-review-001",
    "high": "fake-capable-001",
}
ALIASES = {"haiku": "fast", "sonnet": "balanced", "opus": "high"}
PRIMARY = "fake-primary-001"
REPO_ROOT = pathlib.Path(__file__).resolve().parents[1]
LIFECYCLE_FOLD = REPO_ROOT / "shared" / "scripts" / "mechanics" / "lifecycle-fold.sh"
RUN_ID_PATTERN = re.compile(
    r"[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}-[0-9]{2}-[0-9]{2}Z"
)
BINDING_ID_PATTERN = re.compile(
    r"binding-[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}"
)
UTC_TIMESTAMP_PATTERN = re.compile(
    r"[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}"
    r"(?:\.[0-9]+)?(?:Z|\+00:00)"
)


def without_yaml_comment(value):
    quote = None
    escaped = False
    rendered = []
    for character in value:
        if escaped:
            rendered.append(character)
            escaped = False
            continue
        if quote == '"' and character == "\\":
            rendered.append(character)
            escaped = True
            continue
        if character in {"'", '"'}:
            if quote is None:
                quote = character
            elif quote == character:
                quote = None
            rendered.append(character)
            continue
        if character == "#" and quote is None:
            break
        rendered.append(character)
    return "".join(rendered).strip()


def split_yaml_items(value):
    items = []
    start = 0
    quote = None
    depth = 0
    for index, character in enumerate(value):
        if character in {"'", '"'}:
            if quote is None:
                quote = character
            elif quote == character:
                quote = None
        elif quote is None and character in "[{":
            depth += 1
        elif quote is None and character in "]}":
            depth -= 1
        elif quote is None and depth == 0 and character == ",":
            items.append(value[start:index].strip())
            start = index + 1
    items.append(value[start:].strip())
    return items


def yaml_value(value):
    value = without_yaml_comment(value)
    if value == "":
        return None
    if len(value) >= 2 and value[0] == value[-1] == '"':
        try:
            return json.loads(value)
        except ValueError:
            return object()
    if len(value) >= 2 and value[0] == value[-1] == "'":
        return value[1:-1].replace("''", "'")
    if value == "true":
        return True
    if value == "false":
        return False
    if value in {"null", "~"}:
        return None
    if re.fullmatch(r"-?(0|[1-9][0-9]*)", value):
        return int(value)
    if value.startswith("[") and value.endswith("]"):
        inner = value[1:-1].strip()
        return [] if not inner else [yaml_value(item) for item in split_yaml_items(inner)]
    return value


def inline_yaml_map(value):
    value = without_yaml_comment(value)
    if not (value.startswith("{") and value.endswith("}")):
        return None
    fields = {}
    for item in split_yaml_items(value[1:-1]):
        if ":" not in item:
            return None
        key, raw_value = item.split(":", 1)
        key = key.strip()
        if not re.fullmatch(r"[a-z_]+", key) or key in fields:
            return None
        fields[key] = yaml_value(raw_value)
    return fields


def parse_candidate_config(text):
    """Parse and validate the canonical config-v2 subset used by migration."""
    top = {}
    nested = {}
    query_rows = []
    section = None
    malformed = False
    current_query = None
    block_list_field = None
    for raw_line in text.splitlines():
        if not raw_line.strip() or raw_line.lstrip().startswith("#"):
            continue
        if raw_line == raw_line.lstrip() and ":" in raw_line:
            key, value = raw_line.split(":", 1)
            section = key.strip()
            if section in top:
                malformed = True
            top[section] = yaml_value(value)
            current_query = None
            block_list_field = None
            continue
        if section not in {"workspace", "queries", "search", "schedule", "notify"}:
            continue
        if section == "queries" and raw_line.startswith("  - "):
            item = raw_line[4:].strip()
            current_query = inline_yaml_map(item)
            if current_query is None and ":" in item:
                key, raw_value = item.split(":", 1)
                key = key.strip()
                if re.fullmatch(r"[a-z_]+", key):
                    current_query = {key: yaml_value(raw_value)}
            if current_query is None:
                malformed = True
            else:
                query_rows.append(current_query)
            continue
        if section == "queries" and raw_line.startswith("    ") and current_query is not None:
            match = re.match(r"^    ([a-z_]+):\s*(.*)$", raw_line)
            if not match or match.group(1) in current_query:
                malformed = True
            else:
                current_query[match.group(1)] = yaml_value(match.group(2))
            continue
        if section != "queries" and raw_line.startswith("    "):
            if block_list_field == ("search", "sources"):
                item_match = re.match(r"^    -\s+(.*)$", raw_line)
                item = yaml_value(item_match.group(1)) if item_match else None
                if not isinstance(item, str) or not item:
                    malformed = True
                else:
                    nested[block_list_field].append(item)
            continue
        match = re.match(r"^  ([a-z_]+):\s*(.*)$", raw_line)
        if match:
            field = (section, match.group(1))
            if top.get(section) is not None or field in nested:
                malformed = True
            raw_value = match.group(2)
            if field == ("search", "sources") and without_yaml_comment(raw_value) == "":
                nested[field] = []
                block_list_field = field
            else:
                nested[field] = yaml_value(raw_value)
                block_list_field = None
            continue
        malformed = True

    required_query_fields = {"id", "keywords"}
    if malformed or top.get("version") != 2:
        return None
    if not {"queries", "search"}.issubset(top):
        return None
    if any(
        top[section] is not None
        for section in ("workspace", "queries", "search", "schedule", "notify")
        if section in top
    ):
        return None
    if ("search", "detail_model") not in nested:
        return None
    string_fields = {
        ("workspace", "preferences_path"),
        ("workspace", "master_resume_path"),
        ("search", "detail_model"),
        ("schedule", "frequency"),
        ("schedule", "time"),
        ("schedule", "timezone"),
        ("notify", "digest_path_template"),
    }
    if any(
        not isinstance(nested[field], str) or not nested[field].strip()
        for field in string_fields.intersection(nested)
    ):
        return None
    frequency = nested.get(("schedule", "frequency"), "daily")
    if frequency not in {
        "hourly",
        "every-2-hours",
        "every-6-hours",
        "daily",
        "weekly",
    }:
        return None
    schedule_time = nested.get(("schedule", "time"), "08:00")
    if not re.fullmatch(r"(?:[01][0-9]|2[0-3]):[0-5][0-9]", schedule_time):
        return None
    notify_block = nested.get(("notify", "desktop_notify_on_block"), True)
    if ("notify", "desktop_notify_on_block") in nested and not isinstance(
        notify_block, bool
    ):
        return None
    freshness = nested.get(("search", "freshness"), "past-2-weeks")
    if freshness not in {"any", "past-week", "past-2-weeks", "past-month"}:
        return None
    sources = nested.get(("search", "sources"), ["linkedin", "ashby"])
    if (
        not isinstance(sources, list)
        or not sources
        or any(source not in {"linkedin", "ashby", "greenhouse", "lever"} for source in sources)
        or len(sources) != len(set(sources))
    ):
        return None
    parallel = nested.get(("search", "parallel_detail_reads"), False)
    if ("search", "parallel_detail_reads") in nested and not isinstance(parallel, bool):
        return None
    if ("search", "max_new_postings_per_run") in nested:
        depth = nested[("search", "max_new_postings_per_run")]
        if not (
            (isinstance(depth, int) and not isinstance(depth, bool) and depth > 0)
            or depth == "all"
        ):
            return None
    if not query_rows:
        return None
    for query in query_rows:
        if not required_query_fields.issubset(query):
            return None
        if any(
            not isinstance(query[field], str) or not query[field].strip()
            for field in ("id", "keywords")
        ):
            return None
        if "location" in query and not isinstance(query["location"], str):
            return None
        if "limit" in query and (
            isinstance(query["limit"], bool)
            or not isinstance(query["limit"], int)
            or not 1 <= query["limit"] <= 100
        ):
            return None
        if "enabled" in query and not isinstance(query["enabled"], bool):
            return None
    return {"detail_model": nested[("search", "detail_model")]}


def valid_binding(binding, detail_model):
    if not isinstance(binding, dict) or set(binding) != {
        "version",
        "binding_id",
        "detail_model",
        "detail_model_origin",
        "bound_at",
    }:
        return False
    if type(binding["version"]) is not int or binding["version"] != 1:
        return False
    if not isinstance(binding["binding_id"], str) or not BINDING_ID_PATTERN.fullmatch(
        binding["binding_id"]
    ):
        return False
    if binding["detail_model"] != detail_model or detail_model not in {
        *ROSTER.values(),
        PRIMARY,
    }:
        return False
    if binding["detail_model_origin"] not in {
        "configured_auto",
        "configured_user",
        "repair",
    }:
        return False
    try:
        bound_at = datetime.fromisoformat(binding["bound_at"])
    except (TypeError, ValueError):
        return False
    return bound_at.tzinfo is not None and bound_at.utcoffset() == timedelta(0)


def regular_nonsymlink_file(path):
    try:
        return path.is_file() and not path.is_symlink()
    except OSError:
        return False


def atomic_write_bytes(path, payload):
    path.parent.mkdir(parents=True, exist_ok=True)
    fd, temp_name = tempfile.mkstemp(prefix=path.name + ".", dir=str(path.parent))
    try:
        with os.fdopen(fd, "wb") as handle:
            handle.write(payload)
        os.replace(temp_name, path)
    except BaseException:
        try:
            os.unlink(temp_name)
        except FileNotFoundError:
            pass
        raise


def valid_run_id(run_id):
    if not isinstance(run_id, str) or not RUN_ID_PATTERN.fullmatch(run_id):
        return False
    try:
        datetime.strptime(run_id, "%Y-%m-%dT%H-%M-%SZ")
    except ValueError:
        return False
    return True


def valid_utc_timestamp(value):
    if not isinstance(value, str) or not UTC_TIMESTAMP_PATTERN.fullmatch(value):
        return False
    normalized = value[:-1] + "+00:00" if value.endswith("Z") else value
    try:
        timestamp = datetime.fromisoformat(normalized)
    except ValueError:
        return False
    return timestamp.utcoffset() == timedelta(0)


def fold_lifecycle(workspace, run_id):
    ledger = workspace / "runs" / f".lifecycle-{run_id}.jsonl"
    result = subprocess.run(
        ["sh", str(LIFECYCLE_FOLD), str(ledger), str(workspace)],
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        return None
    folded = {}
    for line in result.stdout.splitlines():
        if "=" not in line:
            return None
        key, value = line.split("=", 1)
        folded[key] = value
    return folded


def canonical_cutoff_evidence(workspace, run_id, migration_snapshot):
    if not valid_run_id(run_id) or not workspace.is_dir():
        return None
    config_path = workspace / "config.yaml"
    binding_path = workspace / "runs" / "detail-model-binding.json"
    run_record_path = workspace / "runs" / f"{run_id}.json"
    try:
        config = parse_candidate_config(config_path.read_text(encoding="utf-8"))
        with run_record_path.open(encoding="utf-8") as handle:
            run_record = json.load(handle)
        with binding_path.open(encoding="utf-8") as handle:
            binding = json.load(handle)
    except (OSError, ValueError):
        return None
    if not isinstance(config, dict) or not isinstance(run_record, dict):
        return None
    detail_model = config.get("detail_model")
    binding_id = binding.get("binding_id") if isinstance(binding, dict) else None
    folded = fold_lifecycle(workspace, run_id)
    qualified = all(
        (
            regular_nonsymlink_file(run_record_path),
            regular_nonsymlink_file(binding_path),
            regular_nonsymlink_file(config_path),
            run_record.get("run_id") == run_id,
            valid_utc_timestamp(run_record.get("completed_at")),
            run_record.get("run_health") in {"healthy", "partial", "degraded"},
            valid_binding(binding, detail_model),
            run_record.get("detail_model_binding_id") == binding_id,
            run_record.get("detail_model") == detail_model,
            isinstance(folded, dict),
            folded.get("run_id") == run_id if isinstance(folded, dict) else False,
            folded.get("can_complete") == "true"
            if isinstance(folded, dict)
            else False,
            folded.get("final_run_record_written") == "true"
            if isinstance(folded, dict)
            else False,
            folded.get("final_digest_written") == "true"
            if isinstance(folded, dict)
            else False,
            isinstance(migration_snapshot, dict),
            migration_snapshot.get("activation_stage") == "pair_active"
            if isinstance(migration_snapshot, dict)
            else False,
            migration_snapshot.get("activated_binding_id") == binding_id
            if isinstance(migration_snapshot, dict)
            else False,
            migration_snapshot.get("activated_detail_model") == detail_model
            if isinstance(migration_snapshot, dict)
            else False,
        )
    )
    if not qualified:
        return None
    return {
        "binding_id": binding_id,
        "detail_model": detail_model,
        "run_id": run_id,
    }


def emit(value, *, stream=sys.stdout, status=0):
    print(json.dumps(value, sort_keys=True), file=stream)
    raise SystemExit(status)


def fail(error, **evidence):
    emit({"error": error, **evidence}, stream=sys.stderr, status=1)


def log(operation, arguments, outcome):
    if not LOG_PATH:
        return
    path = pathlib.Path(LOG_PATH)
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("a", encoding="utf-8") as handle:
        handle.write(
            json.dumps(
                {
                    "operation": operation,
                    "arguments": arguments,
                    "scenario": SCENARIO,
                    "outcome": outcome,
                },
                sort_keys=True,
            )
            + "\n"
        )


def read_state():
    if not STATE_PATH or not pathlib.Path(STATE_PATH).exists():
        return {"jobs": {}}
    with pathlib.Path(STATE_PATH).open(encoding="utf-8") as handle:
        state = json.load(handle)
    if not isinstance(state, dict) or not isinstance(state.get("jobs"), dict):
        fail("invalid_test_state")
    for key in ("migration_snapshots", "migration_cutoffs"):
        if key in state and not isinstance(state[key], dict):
            fail("invalid_test_state")
    return state


def write_state(state):
    if not STATE_PATH:
        fail("missing_test_state_path")
    path = pathlib.Path(STATE_PATH)
    path.parent.mkdir(parents=True, exist_ok=True)
    fd, temp_name = tempfile.mkstemp(prefix=path.name + ".", dir=str(path.parent))
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as handle:
            json.dump(state, handle, indent=2, sort_keys=True)
            handle.write("\n")
        os.replace(temp_name, path)
    except BaseException:
        try:
            os.unlink(temp_name)
        except FileNotFoundError:
            pass
        raise


def need_arg(args, index, label):
    if len(args) <= index or not args[index]:
        fail(f"missing_{label}")
    return args[index]


def main(args):
    operation = need_arg(args, 0, "operation")
    arguments = args[1:]

    if operation == "utc-now":
        state = read_state()
        tick = state.get("clock_tick", 0)
        if not isinstance(tick, int) or tick < 0:
            fail("invalid_test_clock")
        instant = datetime(2026, 7, 16, 12, tzinfo=timezone.utc) + timedelta(seconds=tick)
        state["clock_tick"] = tick + 1
        write_state(state)
        log(operation, arguments, "success")
        emit(
            {
                "iso": instant.isoformat(timespec="seconds"),
                "filename_safe": instant.strftime("%Y-%m-%dT%H-%M-%SZ"),
            }
        )

    if operation == "model-roster":
        if SCENARIO == "tier-roster-unavailable":
            log(operation, arguments, "tier_roster_unavailable")
            fail("tier_roster_unavailable")
        log(operation, arguments, "success")
        emit(ROSTER)

    if operation == "resolve-detail":
        selector = need_arg(args, 1, "selector")
        selector = ALIASES.get(selector, selector)
        if selector not in ROSTER:
            log(operation, arguments, "invalid_selector")
            fail("invalid_selector")
        if SCENARIO == "tier-resolution-unavailable":
            log(operation, arguments, "tier_resolution_unavailable")
            fail("tier_resolution_unavailable")
        log(operation, arguments, "success")
        emit({"selector": arguments[0], "exact_model": ROSTER[selector]})

    if operation == "primary-model":
        if SCENARIO == "primary-unknown":
            log(operation, arguments, "primary_unknown")
            fail("primary_unknown")
        log(operation, arguments, "success")
        emit({"exact_model": PRIMARY})

    if operation == "dispatch-exact":
        model = need_arg(args, 1, "exact_model")
        if model not in {*ROSTER.values(), PRIMARY}:
            log(operation, arguments, "exact_model_unavailable")
            fail("exact_model_unavailable")
        if SCENARIO == "exact-dispatch-unsupported":
            log(operation, arguments, "exact_dispatch_unsupported")
            fail("exact_dispatch_unsupported")
        if SCENARIO == "exact-dispatch-refused":
            log(operation, arguments, "exact_dispatch_refused")
            fail("exact_dispatch_refused")
        log(operation, arguments, "success")
        emit({"exact_model": model, "observed_executable": True})

    if operation == "validate-candidate":
        config_path = pathlib.Path(need_arg(args, 1, "candidate_config"))
        binding_path = pathlib.Path(need_arg(args, 2, "candidate_binding"))
        if SCENARIO == "candidate-validation-failure":
            log(operation, arguments, "candidate_validation_failed")
            fail("candidate_validation_failed")
        try:
            config_text = config_path.read_text(encoding="utf-8")
            with binding_path.open(encoding="utf-8") as handle:
                binding = json.load(handle)
        except (OSError, ValueError):
            log(operation, arguments, "candidate_unreadable")
            fail("candidate_unreadable")
        config = parse_candidate_config(config_text)
        if config is None or not valid_binding(binding, config["detail_model"]):
            log(operation, arguments, "candidate_validation_failed")
            fail("candidate_validation_failed")
        log(operation, arguments, "success")
        emit({"candidate": "validated"})

    if operation == "free-preflight":
        if SCENARIO == "preflight-failure":
            log(operation, arguments, "preflight_failed")
            fail("preflight_failed", metered_calls=0)
        log(operation, arguments, "success")
        emit({"status": "ok", "metered_calls": 0})

    if operation == "begin-migration":
        if len(args) != 2:
            fail("invalid_migration_request")
        workspace = pathlib.Path(need_arg(args, 1, "workspace")).resolve()
        config_path = workspace / "config.yaml"
        binding_path = workspace / "runs" / "detail-model-binding.json"
        if not regular_nonsymlink_file(config_path):
            fail("invalid_migration_baseline")
        if binding_path.exists() and not regular_nonsymlink_file(binding_path):
            fail("invalid_migration_baseline")
        config_bytes = config_path.read_bytes()
        prior_binding = binding_path.read_bytes() if binding_path.exists() else None
        state = read_state()
        state.setdefault("migration_snapshots", {})[str(workspace)] = {
            "config_b64": base64.b64encode(config_bytes).decode("ascii"),
            "prior_sidecar_present": prior_binding is not None,
            "prior_sidecar_b64": (
                base64.b64encode(prior_binding).decode("ascii")
                if prior_binding is not None
                else None
            ),
            "activation_stage": "baseline",
        }
        write_state(state)
        log(operation, arguments, "snapshotted")
        emit(
            {
                "config_snapshotted": True,
                "prior_sidecar": "present" if prior_binding is not None else "absent",
            }
        )

    if operation == "activate-pair":
        if len(args) != 4:
            fail("invalid_activation_request")
        workspace = pathlib.Path(need_arg(args, 1, "workspace")).resolve()
        candidate_config_path = pathlib.Path(need_arg(args, 2, "candidate_config"))
        candidate_binding_path = pathlib.Path(need_arg(args, 3, "candidate_binding"))
        state = read_state()
        snapshot = state.get("migration_snapshots", {}).get(str(workspace))
        if not isinstance(snapshot, dict):
            fail("missing_migration_snapshot")
        try:
            config_bytes = candidate_config_path.read_bytes()
            binding_bytes = candidate_binding_path.read_bytes()
            config = parse_candidate_config(config_bytes.decode("utf-8"))
            binding = json.loads(binding_bytes.decode("utf-8"))
        except (OSError, UnicodeError, ValueError):
            fail("candidate_validation_failed")
        if config is None or not valid_binding(binding, config["detail_model"]):
            fail("candidate_validation_failed")
        active_config = workspace / "config.yaml"
        active_binding = workspace / "runs" / "detail-model-binding.json"
        atomic_write_bytes(active_config, config_bytes)
        snapshot["activation_stage"] = "config_only"
        write_state(state)
        if SCENARIO == "partial-activation-failure":
            log(operation, arguments, "partial_activation_failed")
            fail("partial_activation_failed", active_effect="config_only")
        atomic_write_bytes(active_binding, binding_bytes)
        snapshot["activation_stage"] = "pair_active"
        snapshot["activated_binding_id"] = binding["binding_id"]
        snapshot["activated_detail_model"] = binding["detail_model"]
        write_state(state)
        try:
            active_config_data = parse_candidate_config(
                active_config.read_text(encoding="utf-8")
            )
            active_binding_data = json.loads(active_binding.read_text(encoding="utf-8"))
        except (OSError, ValueError):
            fail("activation_reread_failed")
        if active_config_data is None or not valid_binding(
            active_binding_data, active_config_data["detail_model"]
        ):
            fail("activation_reread_failed")
        log(operation, arguments, "complete")
        emit(
            {
                "activation": "complete",
                "detail_model": active_config_data["detail_model"],
            }
        )

    if operation == "register-disabled":
        job_id = need_arg(args, 1, "job_id")
        if SCENARIO == "register-failure":
            log(operation, arguments, "register_failed")
            fail("register_failed")
        state = read_state()
        state["jobs"][job_id] = {"state": "disabled", "fixture_scope": "t3_2_migration"}
        write_state(state)
        log(operation, arguments, "disabled")
        emit({"job_id": job_id, "state": "disabled"})

    if operation == "canary":
        job_id = need_arg(args, 1, "job_id")
        state = read_state()
        if state["jobs"].get(job_id, {}).get("state") != "disabled":
            log(operation, arguments, "job_not_disabled")
            fail("job_not_disabled")
        if SCENARIO == "canary-failure":
            log(operation, arguments, "canary_failed")
            fail("canary_failed", run_state="blocked", completed_at=None)
        if SCENARIO == "started-only":
            log(operation, arguments, "started")
            emit({"run_state": "started", "run_health": None, "completed_at": None})
        log(operation, arguments, "complete")
        emit(
            {
                "run_state": "complete",
                "run_health": "healthy",
                "completed_at": "2026-07-16T12:00:00+00:00",
            }
        )

    if operation == "qualify-cutoff":
        if len(args) != 3:
            log(operation, arguments, "invalid_cutoff_request")
            fail("invalid_cutoff_request")
        workspace = pathlib.Path(need_arg(args, 1, "workspace")).resolve()
        run_id = need_arg(args, 2, "run_id")
        state = read_state()
        migration_snapshot = state.get("migration_snapshots", {}).get(str(workspace))
        evidence = canonical_cutoff_evidence(workspace, run_id, migration_snapshot)
        if evidence is None:
            log(operation, arguments, "cutoff_not_qualified")
            fail("cutoff_not_qualified")
        state.setdefault("migration_cutoffs", {})[str(workspace)] = evidence
        write_state(state)
        log(operation, arguments, "qualified")
        emit({**evidence, "cutoff_qualifies": True})

    if operation == "rollback-migration":
        workspace = pathlib.Path(need_arg(args, 1, "workspace")).resolve()
        job_id = need_arg(args, 2, "job_id")
        state = read_state()
        snapshots = state.get("migration_snapshots", {})
        snapshot = snapshots.get(str(workspace))
        if not isinstance(snapshot, dict):
            log(operation, arguments, "missing_migration_snapshot")
            fail("missing_migration_snapshot")
        cutoffs = state.get("migration_cutoffs", {})
        cutoff = cutoffs.get(str(workspace))
        if isinstance(cutoff, dict):
            marker_matches_migration = (
                cutoff.get("binding_id") == snapshot.get("activated_binding_id")
                and cutoff.get("detail_model")
                == snapshot.get("activated_detail_model")
            )
            if not marker_matches_migration:
                cutoffs.pop(str(workspace), None)
            else:
                evidence = canonical_cutoff_evidence(
                    workspace, cutoff.get("run_id"), snapshot
                )
                if evidence == cutoff:
                    log(operation, arguments, "rollback_forbidden_after_cutoff")
                    fail("rollback_forbidden_after_cutoff")
                log(operation, arguments, "cutoff_evidence_unverifiable")
                fail("cutoff_evidence_unverifiable")
        try:
            original_config = base64.b64decode(snapshot["config_b64"], validate=True)
            prior_present = snapshot["prior_sidecar_present"] is True
            prior_sidecar = (
                base64.b64decode(snapshot["prior_sidecar_b64"], validate=True)
                if prior_present
                else None
            )
        except (KeyError, TypeError, ValueError):
            fail("invalid_test_state")
        config_path = workspace / "config.yaml"
        binding_path = workspace / "runs" / "detail-model-binding.json"
        atomic_write_bytes(config_path, original_config)
        if prior_present:
            atomic_write_bytes(binding_path, prior_sidecar)
            sidecar_effect = "restored_exact"
        else:
            try:
                binding_path.unlink()
            except FileNotFoundError:
                pass
            sidecar_effect = "removed"
        if job_id not in state["jobs"]:
            job_state = "not_created"
        elif SCENARIO == "remove-unavailable":
            state["jobs"][job_id]["state"] = "disabled"
            job_state = "disabled"
        else:
            state["jobs"].pop(job_id, None)
            job_state = "absent"
        snapshots.pop(str(workspace), None)
        write_state(state)
        log(operation, arguments, f"restored_{job_state}")
        emit(
            {
                "config": "restored_exact",
                "job_id": job_id,
                "job_state": job_state,
                "sidecar": sidecar_effect,
            }
        )

    if operation in {"remove-job", "disable-job"}:
        job_id = need_arg(args, 1, "job_id")
        state = read_state()
        if operation == "remove-job":
            state["jobs"].pop(job_id, None)
            rendered_state = "absent"
        else:
            state["jobs"].setdefault(job_id, {})["state"] = "disabled"
            rendered_state = "disabled"
        write_state(state)
        log(operation, arguments, rendered_state)
        emit({"job_id": job_id, "state": rendered_state})

    fail("unsupported_operation", operation=operation)


if __name__ == "__main__":
    main(sys.argv[1:])
