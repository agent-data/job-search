class Coordinator:
    def __init__(self, scenario, workspace, trigger, scheduler_arg):
        self.scenario = scenario
        self.workspace = workspace
        self.trigger = trigger
        self.scheduler_arg = scheduler_arg
        self.scheduler_id = None if scheduler_arg == "-" else scheduler_arg
        self.ledger = workspace / "runs" / (".lifecycle-%s.jsonl" % RUN_ID)
        self.jobs = workspace / "jobs.jsonl"
        self.effects = []
        self.run_record_valid = False
        self.digest_valid = False
        self.validated_before_complete_close = False
        self.complete_close_attempted = False
        self.preserved_judgment_bytes = None
        self.artifact_failure_injected = False
        self.coordinator_reinstantiated = False
        self.reconstructed_posting_states = {}
        self.reconstructed_job_identities = []
        self.reconstructed_attempt_ids = []
        self.intended_complete_files_existed_before_close = False
        self.public_complete_authorized_before_close = None
        self.canary_authorized_before_close = None
        self.public_complete_authorized_after_close = None

    @classmethod
    def recover(cls, scenario, workspace):
        ledger = workspace / "runs" / (".lifecycle-%s.jsonl" % RUN_ID)
        rows = [json.loads(line) for line in ledger.read_text().splitlines()]
        started = rows[0]
        scheduler_arg = started["scheduler_id"] if started["scheduler_id"] is not None else "-"
        recovered = cls(scenario, workspace, started["trigger"], scheduler_arg)
        recovered.effects = ["context_recovered_from_durable_files"]
        recovered.coordinator_reinstantiated = True
        for row in rows:
            if row["event"] == "posting_state":
                identity = "%s:%s" % (row["source"], row["source_id"])
                recovered.reconstructed_posting_states[identity] = row["state"]
        if recovered.jobs.exists():
            current_run_jobs = set()
            for row in (
                json.loads(line) for line in recovered.jobs.read_text().splitlines()
            ):
                if row.get("event") != "evaluated" or row.get("run_id") != RUN_ID:
                    continue
                if not recovered.valid_evaluated_job_event(row):
                    raise RuntimeError("current-run jobs evidence was malformed")
                current_run_jobs.add("%s:%s" % (row["source"], row["source_id"]))
            recovered.reconstructed_job_identities = sorted(current_run_jobs)
        recovered.reconstructed_attempt_ids = sorted(
            row["attempt_id"] for row in rows if row["event"] == "attempt_started"
        )
        state = recovered.fold()
        if state["phase"] != "reviewing_initial_batch":
            raise RuntimeError("durable recovery did not reconstruct the review phase")
        return recovered

    def append(self, command, *args):
        result = subprocess.run(
            [
                "sh",
                str(APPEND),
                str(self.ledger),
                command,
                RUN_ID,
                TIMESTAMP,
                *args,
            ],
            capture_output=True,
            text=True,
        )
        if result.returncode != 0:
            raise RuntimeError("append %s failed: %s" % (command, result.stderr.strip()))

    def fold(self):
        result = subprocess.run(
            ["sh", str(FOLD), str(self.ledger), str(self.workspace)],
            capture_output=True,
            text=True,
        )
        if result.returncode != 0:
            raise RuntimeError("fold failed: %s" % result.stderr.strip())
        values = {}
        for line in result.stdout.splitlines():
            key, value = line.split("=", 1)
            values[key] = value
        return values

    def start(self):
        self.append("start", self.trigger, self.scheduler_arg)
        self.effects.append("ledger_started")

    def phase(self, phase):
        self.append("phase", phase)
        self.effects.append("phase:%s" % phase)

    def posting(self, source_id, state, source="linkedin"):
        self.append("posting", source, source_id, state, REVISION)
        self.effects.append("posting_%s" % state)

    def producer(
        self,
        attempt_id,
        operation,
        metered,
        outcome,
        request_id,
        account=True,
        logical_operation_id=None,
        attempt_number=1,
    ):
        logical_operation_id = logical_operation_id or attempt_id
        self.append(
            "attempt-started",
            attempt_id,
            operation,
            logical_operation_id,
            str(attempt_number),
        )
        self.effects.append("attempt_started:%s" % attempt_id)
        # The next effect is the simulated producer invocation.  Its returned status below is the sole
        # source of metered/outcome/request evidence; the fixture never infers billing from an exception.
        self.effects.append("producer_call:%s" % attempt_id)
        if account:
            self.append(
                "attempt-accounted",
                attempt_id,
                "true" if metered else "false",
                outcome,
                request_id if request_id is not None else "-",
            )
            self.effects.append("attempt_accounted:%s" % attempt_id)

