    def valid_evaluated_job_event(self, row):
        required = {
            "company_name", "dealbreakers_hit", "detail_read", "event", "first_seen",
            "location_display", "match", "needs_human_check", "posting_id_at_seen",
            "posted_at", "query_id", "reasoning", "relevant", "run_id", "salary_display",
            "source", "source_id", "source_url", "status", "title", "ts", "unknowns",
        }
        optional = {"posted_at_extracted", "same_role_as"}
        if not isinstance(row, dict) or set(row) - (required | optional) or not required.issubset(row):
            return False
        if row["event"] != "evaluated" or row["run_id"] != RUN_ID:
            return False
        if row["source"] not in ("linkedin", "ashby", "greenhouse", "lever"):
            return False
        string_fields = (
            "company_name", "first_seen", "location_display", "posting_id_at_seen",
            "query_id", "reasoning", "source_id", "source_url", "title", "ts",
        )
        if not all(isinstance(row[key], str) and row[key].strip() for key in string_fields):
            return False
        if not isinstance(row["salary_display"], str):
            return False
        if row["posted_at"] is not None and not (
            isinstance(row["posted_at"], str) and row["posted_at"].strip()
        ):
            return False
        if not all(type(row[key]) is bool for key in ("detail_read", "relevant", "needs_human_check")):
            return False
        if row["match"] not in ("strong", "moderate", "weak", None):
            return False
        if row["relevant"] is False and row["match"] is not None:
            return False
        if row["relevant"] is True and row["match"] is None:
            return False
        if row["status"] not in ("new", "interested", "applied", "rejected", "archived"):
            return False
        if not all(
            isinstance(row[key], list)
            and all(isinstance(item, str) for item in row[key])
            for key in ("dealbreakers_hit", "unknowns")
        ):
            return False
        if "posted_at_extracted" in row and not isinstance(row["posted_at_extracted"], str):
            return False
        if "same_role_as" in row and not isinstance(row["same_role_as"], str):
            return False
        return True

    def render_and_present(self, succeeds, source_id="posting-1"):
        if succeeds:
            self.effects.append("interactive_render_succeeded")
            self.posting(source_id, "presented")
        else:
            self.effects.append("interactive_render_failed")

    def resume_recovered_work(self):
        rows = self.ledger_rows()
        starts = {
            row["attempt_id"]: row
            for row in rows
            if row["event"] == "attempt_started"
        }
        successful_logical_operations = {
            starts[row["attempt_id"]]["logical_operation_id"]
            for row in rows
            if row["event"] == "attempt_accounted"
            and row["outcome"] == "success"
            and row["attempt_id"] in starts
        }
        durable_jobs = set(self.reconstructed_job_identities)
        resumed_jobs = []
        recovery_attempt = 0
        for identity, posting_state in sorted(self.reconstructed_posting_states.items()):
            source, source_id = identity.split(":", 1)
            logical_operation_id = "detail-%s-%s" % (source, source_id)
            if posting_state == "evaluating":
                if identity not in durable_jobs or logical_operation_id not in successful_logical_operations:
                    raise RuntimeError("evaluating posting lacked durable result evidence")
                self.posting(source_id, "evaluated", source=source)
                resumed_jobs.append(identity)
            elif posting_state == "queued":
                recovery_attempt += 1
                attempt_id = "detail-recovered-%d" % recovery_attempt
                self.posting(source_id, "evaluating", source=source)
                self.producer(
                    attempt_id,
                    "detail_read",
                    True,
                    "success",
                    "request-%s" % attempt_id,
                    logical_operation_id=logical_operation_id,
                )
                self.evaluated_job(source_id, source=source)
                self.posting(source_id, "evaluated", source=source)
                resumed_jobs.append(identity)
            elif posting_state not in ("evaluated", "presented", "terminally_skipped"):
                raise RuntimeError("recovery found an unknown posting state")
        return resumed_jobs

