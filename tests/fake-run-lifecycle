def marked_forbidden_model_values():
    text = CONVENTIONS.read_text(encoding="utf-8")
    match = re.search(
        r"<!-- exact-model-contract:forbidden-run-record-values -->\n(.*?)\n"
        r"<!-- /exact-model-contract:forbidden-run-record-values -->",
        text,
        re.DOTALL,
    )
    if match is None:
        raise RuntimeError("canonical forbidden run-record model vocabulary is missing")
    values = frozenset(re.findall(r"^- `([^`]+)`$", match.group(1), re.MULTILINE))
    if not values:
        raise RuntimeError("canonical forbidden run-record model vocabulary is empty")
    return values


