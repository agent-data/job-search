    def validate_run_record(self, record):
        def exact_keys(value, keys):
            return isinstance(value, dict) and set(value) == set(keys)

        def nonempty(value):
            return isinstance(value, str) and bool(value.strip())

        def count(value):
            return type(value) is int and value >= 0

        def timestamp(value):
            if not nonempty(value):
                return False
            if re.fullmatch(
                r"[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\.[0-9]+)?(?:Z|[+-][0-9]{2}:[0-9]{2})",
                value,
            ) is None:
                return False
            try:
                datetime.fromisoformat(value.replace("Z", "+00:00"))
            except ValueError:
                return False
            return True

        def decimal_or_none(value):
            return value is None or (
                isinstance(value, str)
                and re.fullmatch(r"(?:0|[1-9][0-9]*)(?:\.[0-9]+)?", value) is not None
            )

        def exact_model(value):
            return nonempty(value) and value not in (
                "auto", "balanced", "fast", "high", "quality", "inherit",
                "haiku", "sonnet", "opus",
            )

        def valid_attempt_error(error):
            required_error = {
                "stage", "code", "retryable", "attempts", "final", "request_id"
            }
            if not isinstance(error, dict) or not required_error.issubset(error):
                return False
            if set(error) - (required_error | {"source_id"}):
                return False
            if not all(nonempty(error[key]) for key in ("stage", "code", "final")):
                return False
            if type(error["retryable"]) is not bool:
                return False
            if not count(error["attempts"]) or error["attempts"] == 0:
                return False
            if error["request_id"] is not None and not nonempty(error["request_id"]):
                return False
            if "source_id" in error and not nonempty(error["source_id"]):
                return False
            return True

        required = {
            "agent_data_usage", "build", "completed_at", "detail_model",
            "detail_model_binding_id", "detail_model_origin", "error", "errors",
            "lifecycle", "pagination_metrics", "primary_model", "primary_model_origin",
            "queries", "results_summary", "review_scope", "run_health", "run_id",
            "scheduler_id", "sources_failed", "sources_searched", "started_at",
            "status_probe", "trigger",
        }
        if not exact_keys(record, required) or record["run_id"] != RUN_ID:
            return False
        if re.fullmatch(r"[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}-[0-9]{2}-[0-9]{2}Z", record["run_id"]) is None:
            return False
        if not timestamp(record["started_at"]) or not timestamp(record["completed_at"]):
            return False
        if datetime.fromisoformat(record["completed_at"].replace("Z", "+00:00")) < datetime.fromisoformat(record["started_at"].replace("Z", "+00:00")):
            return False
        build = record["build"]
        if not exact_keys(build, {"version", "content_hash", "git_sha"}):
            return False
        if re.fullmatch(r"[0-9]+\.[0-9]+\.[0-9]+", build["version"]) is None:
            return False
        if re.fullmatch(r"sha256:[0-9a-f]{12}", build["content_hash"]) is None:
            return False
        if build["git_sha"] != "unknown" and re.fullmatch(r"[0-9a-f]{7,40}", build["git_sha"]) is None:
            return False
        if record["trigger"] not in ("manual", "scheduled", "canary"):
            return False
        if (record["trigger"] == "manual") != (record["scheduler_id"] is None):
            return False
        if record["scheduler_id"] is not None and not nonempty(record["scheduler_id"]):
            return False
        if not exact_model(record["primary_model"]):
            return False
        if record["primary_model_origin"] not in (
            "session_inheritance", "user_override", "repair_session"
        ):
            return False
        if record["status_probe"] not in ("ok", "degraded", "unreachable"):
            return False
        if record["status_probe"] == "unreachable" and record["run_health"] != "blocked":
            return False
        detail_values = (
            record["detail_model"],
            record["detail_model_origin"],
            record["detail_model_binding_id"],
        )
        binding_block = (
            record["run_health"] == "blocked"
            and isinstance(record["error"], dict)
            and record["error"].get("class") == "detail_model_binding_unavailable"
        )
        if binding_block:
            if detail_values != (None, None, None):
                return False
        else:
            if not exact_model(record["detail_model"]):
                return False
            if record["detail_model_origin"] not in (
                "configured_auto", "configured_user", "legacy_v1_selector", "repair"
            ):
                return False
            if record["detail_model_origin"] == "legacy_v1_selector":
                if record["detail_model_binding_id"] is not None:
                    return False
            elif not nonempty(record["detail_model_binding_id"]):
                return False

        lifecycle = record["lifecycle"]
        if not exact_keys(lifecycle, {"phase", "close_state", "health"}):
            return False
        phases = (
            "preflight", "searching", "selection_settled", "reviewing_initial_batch",
            "early_results_shown", "reviewing_remaining", "finalizing", "complete",
        )
        if lifecycle["phase"] not in phases:
            return False
        if lifecycle["close_state"] not in ("complete", "blocked", "interrupted"):
            return False
        if record["run_health"] not in ("healthy", "partial", "degraded", "blocked"):
            return False
        if lifecycle["health"] != record["run_health"]:
            return False
        if lifecycle["close_state"] == "complete":
            if lifecycle["phase"] != "complete" or record["run_health"] == "blocked":
                return False
            if record["error"] is not None:
                return False
        elif lifecycle["phase"] == "complete" or record["run_health"] != "blocked":
            return False
        elif binding_block:
            if not exact_keys(record["error"], {"class"}):
                return False
        else:
            if not exact_keys(record["error"], {"code"}):
                return False
            if re.fullmatch(r"E-[A-Z0-9]+(?:-[A-Z0-9]+)*", record["error"]["code"]) is None:
                return False

        if not isinstance(record["queries"], list):
            return False
        if not record["queries"] and not (
            binding_block and lifecycle["phase"] == "preflight"
        ):
            return False
        query_keys = {
            "query_id", "source", "keywords", "results_returned", "new", "pages_fetched",
            "rows_scanned", "unique_candidates", "selected_for_review", "has_more_at_stop",
            "stop_reason", "attempts", "request_ids", "upstream_code", "retryable", "errors",
        }
        for query in record["queries"]:
            if not exact_keys(query, query_keys):
                return False
            if not all(nonempty(query[key]) for key in ("query_id", "keywords")):
                return False
            if query["source"] not in ("linkedin", "ashby", "greenhouse", "lever"):
                return False
            if not all(count(query[key]) for key in (
                "results_returned", "new", "pages_fetched", "rows_scanned",
                "unique_candidates", "selected_for_review", "attempts",
            )):
                return False
            if query["new"] > query["results_returned"] or query["selected_for_review"] > query["unique_candidates"]:
                return False
            if query["has_more_at_stop"] is not None and type(query["has_more_at_stop"]) is not bool:
                return False
            if query["stop_reason"] not in (
                "first_page_complete", "target_reached", "sources_exhausted", "unpaginated",
                "pagination_incomplete", "source_failed",
            ):
                return False
            if query["stop_reason"] == "unpaginated" and query["source"] != "linkedin":
                return False
            if query["source"] == "linkedin" and query["stop_reason"] != "unpaginated":
                return False
            if query["source"] == "linkedin" and query["has_more_at_stop"] is not None:
                return False
            if not isinstance(query["request_ids"], list) or not all(nonempty(item) for item in query["request_ids"]):
                return False
            if query["upstream_code"] is not None and not nonempty(query["upstream_code"]):
                return False
            if query["retryable"] is not None and type(query["retryable"]) is not bool:
                return False
            if not isinstance(query["errors"], list) or not all(
                valid_attempt_error(error) for error in query["errors"]
            ):
                return False

        sources = ("linkedin", "ashby", "greenhouse", "lever")
        for key in ("sources_searched", "sources_failed"):
            if not isinstance(record[key], list) or not all(item in sources for item in record[key]):
                return False
            if len(record[key]) != len(set(record[key])):
                return False
        if not set(record["sources_failed"]).issubset(set(record["sources_searched"])):
            return False
        if any(
            query["source"] not in record["sources_searched"]
            for query in record["queries"]
        ):
            return False

        review = record["review_scope"]
        if not exact_keys(review, {"mode", "target_new_postings", "origin", "outcome"}):
            return False
        if review["mode"] not in ("first_page", "finite", "all"):
            return False
        if review["origin"] not in ("default", "one_off", "saved"):
            return False
        if review["outcome"] not in (
            "completed_first_pages", "target_reached", "sources_exhausted", "incomplete"
        ):
            return False
        if review["mode"] == "finite":
            if not count(review["target_new_postings"]) or review["target_new_postings"] == 0:
                return False
        elif review["target_new_postings"] is not None:
            return False

        usage = record["agent_data_usage"]
        if not exact_keys(usage, {
            "metered_calls", "unit_rate_usd", "payg_equivalent_usd",
            "pricing_basis", "by_operation", "diagnostics",
        }):
            return False
        if not count(usage["metered_calls"]):
            return False
        if not decimal_or_none(usage["unit_rate_usd"]) or not decimal_or_none(usage["payg_equivalent_usd"]):
            return False
        if (usage["unit_rate_usd"] is None) != (usage["payg_equivalent_usd"] is None):
            return False
        if usage["pricing_basis"] != "pay_as_you_go_equivalent":
            return False
        if not exact_keys(usage["by_operation"], {"initial_search", "continuation_search", "detail_read"}):
            return False
        if not all(count(value) for value in usage["by_operation"].values()):
            return False
        if sum(usage["by_operation"].values()) != usage["metered_calls"]:
            return False
        diagnostics = usage["diagnostics"]
        if not exact_keys(diagnostics, {"retry_attempts", "charged_failures", "quota_rejections", "free_route_calls"}):
            return False
        if not all(count(value) for value in diagnostics.values()):
            return False

        pagination = record["pagination_metrics"]
        pagination_counts = {
            "first_page_rows", "continuation_rows", "known_rows",
            "same_run_cross_query_duplicate_rows", "cross_source_rows_merged",
            "unique_unseen_roles_first_pages", "unique_unseen_roles_continuations",
            "selected_roles_from_continuations",
        }
        if not exact_keys(pagination, pagination_counts | {
            "deeper_coverage_nudge_eligible", "deeper_coverage_nudge_streams"
        }):
            return False
        if not all(count(pagination[key]) for key in pagination_counts):
            return False
        if type(pagination["deeper_coverage_nudge_eligible"]) is not bool:
            return False
        if not isinstance(pagination["deeper_coverage_nudge_streams"], list) or not all(
            nonempty(item) for item in pagination["deeper_coverage_nudge_streams"]
        ):
            return False
        nudge_streams = pagination["deeper_coverage_nudge_streams"]
        if len(nudge_streams) != len(set(nudge_streams)):
            return False
        if not pagination["deeper_coverage_nudge_eligible"]:
            if nudge_streams:
                return False
        else:
            if (
                review["mode"] != "first_page"
                or review["outcome"] != "completed_first_pages"
                or pagination["unique_unseen_roles_first_pages"] != 0
                or not nudge_streams
            ):
                return False
            healthy_cursor_streams = {
                "%s:%s" % (query["query_id"], query["source"])
                for query in record["queries"]
                if query["source"] in ("ashby", "greenhouse", "lever")
                and query["source"] not in record["sources_failed"]
                and query["has_more_at_stop"] is True
            }
            if not set(nudge_streams).issubset(healthy_cursor_streams):
                return False

        summary = record["results_summary"]
        summary_keys = {
            "total_results", "new_postings", "evaluated", "detail_read",
            "relevant", "strong", "moderate", "weak",
        }
        if not exact_keys(summary, summary_keys) or not all(count(summary[key]) for key in summary_keys):
            return False
        if summary["new_postings"] > summary["total_results"] or summary["evaluated"] > summary["new_postings"]:
            return False
        if summary["detail_read"] > summary["evaluated"]:
            return False
        if summary["relevant"] != summary["strong"] + summary["moderate"] + summary["weak"]:
            return False
        if summary["relevant"] > summary["evaluated"]:
            return False

        if not isinstance(record["errors"], list):
            return False
        if not all(valid_attempt_error(error) for error in record["errors"]):
            return False
        if binding_block and lifecycle["phase"] == "preflight":
            if record["queries"] or record["sources_searched"] or record["sources_failed"]:
                return False
            if usage["metered_calls"] != 0 or any(usage["by_operation"].values()):
                return False
            if any(usage["diagnostics"].values()):
                return False
            if usage["unit_rate_usd"] is not None or usage["payg_equivalent_usd"] is not None:
                return False
            if any(pagination[key] for key in pagination_counts):
                return False
            if pagination["deeper_coverage_nudge_eligible"] or nudge_streams:
                return False
            if any(summary.values()) or record["errors"]:
                return False
            if review["outcome"] != "incomplete":
                return False
        return True

    def validate_digest(self, digest, record):
        summary = record["results_summary"]
        required_lines = [
            "# Job search digest — 2026-07-17",
            "Run health: %s" % (
                "healthy" if record["run_health"] == "healthy" else "blocked (action needed)"
            ),
            "Agent-data usage: %d metered calls this run"
            % record["agent_data_usage"]["metered_calls"],
        ]
        if not all(line in digest.splitlines() for line in required_lines):
            return False
        counts = next((line for line in digest.splitlines() if " new posting" in line), "")
        if not all(token in counts for token in ("strong", "moderate", "weak", "filtered out", "searches", "detail reads")):
            return False
        if record["lifecycle"]["close_state"] == "complete":
            return summary["strong"] > 0 and all(
                token in digest
                for token in ("## Strong matches", "Deterministic fixture reasoning.", "[view](")
            )
        return "Run could not be safely finalized." in digest

    def write_and_validate_artifacts(self, close_state, record_milestones=True):
        record, digest = self.artifact_values(close_state)
        run_path = self.workspace / "runs" / (RUN_ID + ".json")
        digest_path = self.workspace / "reports" / "2026-07-17-digest.md"

        inject_failure = (
            self.scenario in ("artifact_write_failure", "artifact_validation_failure")
            and not self.artifact_failure_injected
        )
        if inject_failure:
            self.artifact_failure_injected = True
        if inject_failure and self.scenario == "artifact_write_failure":
            self.effects.append("terminal_artifact_write_failed")
            return False
        digest_path.parent.mkdir(parents=True, exist_ok=True)
        if inject_failure and self.scenario == "artifact_validation_failure":
            run_path.write_text('{"run_id":"wrong"}\n', encoding="utf-8")
            digest_path.write_text("# Wrong digest\n", encoding="utf-8")
            self.effects.append("terminal_artifact_validation_failed")
        else:
            run_path.write_text(
                json.dumps(record, indent=2, sort_keys=True) + "\n",
                encoding="utf-8",
            )
            digest_path.write_text(digest, encoding="utf-8")

        try:
            loaded_record = json.loads(run_path.read_text(encoding="utf-8"))
            loaded_digest = digest_path.read_text(encoding="utf-8")
            self.run_record_valid = (
                loaded_record == record and self.validate_run_record(loaded_record)
            )
            self.digest_valid = (
                loaded_digest == digest and self.validate_digest(loaded_digest, loaded_record)
            )
        except (OSError, ValueError):
            self.run_record_valid = False
            self.digest_valid = False
        valid = self.run_record_valid and self.digest_valid
        if valid and record_milestones:
            self.append("milestone", "final_run_record_written")
            self.append("milestone", "final_digest_written")
            self.effects.extend(
                ["final_run_record_validated", "final_digest_validated"]
            )
        return valid

    def public_artifact_authority(self):
        try:
            state = self.fold()
            record = json.loads(
                (self.workspace / "runs" / (RUN_ID + ".json")).read_text(encoding="utf-8")
            )
            digest = (self.workspace / "reports" / "2026-07-17-digest.md").read_text(
                encoding="utf-8"
            )
        except (OSError, RuntimeError, ValueError):
            return False
        if state["run_id"] != RUN_ID or record.get("run_id") != RUN_ID:
            return False
        record_scheduler = record.get("scheduler_id")
        folded_scheduler = None if state["scheduler_id"] == "null" else state["scheduler_id"]
        if record.get("trigger") != state["trigger"] or record_scheduler != folded_scheduler:
            return False
        if state["closed"] != "true":
            return False
        if record.get("lifecycle", {}).get("close_state") != state["close_state"]:
            return False
        if record.get("lifecycle", {}).get("phase") != state["phase"]:
            return False
        if not self.validate_run_record(record) or not self.validate_digest(digest, record):
            return False
        if state["close_state"] == "complete":
            return state["can_complete"] == "true"
        return state["can_complete"] == "false"

    def close(self, close_state, code):
        if close_state == "complete":
            self.complete_close_attempted = True
        self.append("close", close_state, code)
        self.effects.append("run_closed:%s" % close_state)

    def summary(self):
        state = self.fold()
        snapshot_hash = None
        final_prefix_hash = None
        preserved = None
        if self.preserved_judgment_bytes is not None:
            final_bytes = self.jobs.read_bytes()
            prefix = final_bytes[: len(self.preserved_judgment_bytes)]
            snapshot_hash = hashlib.sha256(self.preserved_judgment_bytes).hexdigest()
            final_prefix_hash = hashlib.sha256(prefix).hexdigest()
            preserved = prefix == self.preserved_judgment_bytes
        return {
            "accepted": True,
            "run_id": RUN_ID,
            "ledger_name": self.ledger.name,
            "trigger": state["trigger"],
            "scheduler_id": None if state["scheduler_id"] == "null" else state["scheduler_id"],
            "phase": state["phase"],
            "close_state": state["close_state"],
            "can_complete": state["can_complete"] == "true",
            "remaining": int(state["remaining"]),
            "in_flight": int(state["in_flight"]),
            "attempts_started": int(state["attempts_started"]),
            "attempts_accounted": int(state["attempts_accounted"]),
            "blocking_attempt_failures": int(state["blocking_attempt_failures"]),
            "presented": int(state["presented"]),
            "run_record_valid": self.run_record_valid,
            "digest_valid": self.digest_valid,
            "validated_before_complete_close": self.validated_before_complete_close,
            "complete_close_attempted": self.complete_close_attempted,
            "judgments_preserved": preserved,
            "judgment_snapshot_sha256": snapshot_hash,
            "judgment_final_prefix_sha256": final_prefix_hash,
            "coordinator_reinstantiated": self.coordinator_reinstantiated,
            "reconstructed_posting_states": self.reconstructed_posting_states,
            "reconstructed_job_identities": self.reconstructed_job_identities,
            "reconstructed_attempt_ids": self.reconstructed_attempt_ids,
            "intended_complete_files_existed_before_close": self.intended_complete_files_existed_before_close,
            "public_complete_authorized_before_close": self.public_complete_authorized_before_close,
            "canary_authorized_before_close": self.canary_authorized_before_close,
            "public_complete_authorized_after_close": self.public_complete_authorized_after_close,
            "effects": self.effects,
        }


def validate_attribution(trigger, scheduler_arg):
    if trigger == "manual":
        return scheduler_arg == "-"
    if trigger in ("scheduled", "canary"):
        return scheduler_arg != "-"
    return False


def finish(coordinator, close_state, code):
    artifacts_valid = coordinator.write_and_validate_artifacts(close_state)
    if not artifacts_valid and close_state != "complete":
        if not coordinator.write_and_validate_artifacts(close_state):
            raise RuntimeError("failed to publish truthful blocked terminal artifacts")
        coordinator.effects.append("terminal_artifacts_repaired")
        artifacts_valid = True
    if close_state == "complete":
        if not artifacts_valid:
            raise RuntimeError("complete artifacts did not validate")
        readiness = coordinator.fold()
        if readiness["ready_to_close"] != "true":
            raise RuntimeError("completion predicate was not ready")
        coordinator.validated_before_complete_close = True
        if coordinator.scenario == "complete_close_write_failure":
            coordinator.complete_close_attempted = True
            coordinator.ledger.chmod(0o444)
            try:
                coordinator.append("close", "complete", "-")
            except RuntimeError:
                coordinator.effects.append("complete_close_failed")
            else:
                raise RuntimeError("fixture could not induce the complete-close write failure")
            finally:
                coordinator.ledger.chmod(0o644)
            if not coordinator.write_and_validate_artifacts(
                "blocked", record_milestones=False
            ):
                raise RuntimeError("failed to repair terminal artifacts after close failure")
            coordinator.effects.append("terminal_artifacts_repaired")
            coordinator.close("blocked", "E-FIXTURE-CLOSE-WRITE")
            return
    coordinator.close(close_state, code)
    if close_state == "complete":
        closed = coordinator.fold()
        if closed["can_complete"] != "true":
            raise RuntimeError("post-close fold did not prove completion")
        coordinator.effects.append("post_close_fold_verified")


def run_scenario(scenario, workspace):
    trigger, scheduler_arg = ATTRIBUTION.get(scenario, ("manual", "-"))
    coordinator = Coordinator(scenario, workspace, trigger, scheduler_arg)
    coordinator.start()
    coordinator.phase("searching")
    coordinator.producer("search-1", "initial_search", True, "success", "request-search-1")

    if scenario == "interruption_before_selection":
        finish(coordinator, "interrupted", "E-FIXTURE-INTERRUPTED")
        return coordinator.summary()

    coordinator.posting("posting-1", "queued")
    if scenario in ("remaining_work", "compaction_after_selection"):
        coordinator.posting("posting-2", "queued")
    if scenario in ("quota_during_detail", "worker_failure"):
        coordinator.posting("posting-prior", "queued")

    # The phase marker is the commit point: once it exists, the entire selected queue is already durable.
    coordinator.phase("selection_settled")

    if scenario == "compaction_after_selection":
        coordinator.phase("reviewing_initial_batch")
        coordinator.posting("posting-1", "evaluating")
        coordinator.producer(
            "detail-1",
            "detail_read",
            True,
            "success",
            "request-detail-1",
            logical_operation_id="detail-linkedin-posting-1",
        )
        coordinator.evaluated_job("posting-1")
        coordinator = None
        coordinator = Coordinator.recover(scenario, workspace)
        recovered = coordinator.fold()
        expected_states = {
            "linkedin:posting-1": "evaluating",
            "linkedin:posting-2": "queued",
        }
        if (
            recovered["remaining"] != "1"
            or recovered["in_flight"] != "1"
            or coordinator.reconstructed_posting_states != expected_states
            or coordinator.reconstructed_job_identities != ["linkedin:posting-1"]
        ):
            raise RuntimeError("post-selection compaction could not reconstruct durable work")
        resumed_jobs = coordinator.resume_recovered_work()
        if resumed_jobs != ["linkedin:posting-1", "linkedin:posting-2"]:
            raise RuntimeError("post-selection recovery did not resume durable work")
        presented_source_id = coordinator.reconstructed_job_identities[0].split(":", 1)[1]
        coordinator.render_and_present(True, presented_source_id)
        coordinator.phase("early_results_shown")
        coordinator.append("milestone", "early_results_shown")
        coordinator.effects.append("milestone:early_results_shown")
        coordinator.phase("reviewing_remaining")
        coordinator.phase("finalizing")
        finish(coordinator, "complete", "-")
        return coordinator.summary()

    coordinator.phase("reviewing_initial_batch")

    if scenario in ("quota_during_detail", "worker_failure"):
        coordinator.posting("posting-prior", "evaluating")
        coordinator.producer(
            "detail-prior", "detail_read", True, "success", "request-detail-prior"
        )
        coordinator.evaluated_job("posting-prior")
        coordinator.posting("posting-prior", "evaluated")
        coordinator.preserved_judgment_bytes = coordinator.jobs.read_bytes()

    coordinator.posting("posting-1", "evaluating")

    if scenario == "quota_during_detail":
        coordinator.producer("detail-1", "detail_read", False, "quota_rejected", None)
        coordinator.posting("posting-1", "terminally_skipped")
        finish(coordinator, "blocked", "E-FIXTURE-QUOTA")
        return coordinator.summary()
    if scenario == "worker_failure":
        coordinator.producer("detail-1", "detail_read", True, "worker_failed", "request-detail-1")
        coordinator.posting("posting-1", "terminally_skipped")
        finish(coordinator, "blocked", "E-FIXTURE-WORKER")
        return coordinator.summary()
    if scenario == "in_flight_work":
        coordinator.producer("detail-1", "detail_read", True, "success", "request-detail-1")
        finish(coordinator, "interrupted", "E-FIXTURE-IN-FLIGHT")
        return coordinator.summary()
    if scenario == "unaccounted_retry":
        coordinator.producer(
            "detail-1", "detail_read", True, "retryable_failure", "request-detail-1",
            logical_operation_id="detail-posting-1", attempt_number=1,
        )
        coordinator.producer(
            "detail-2", "detail_read", False, "success", None, account=False,
            logical_operation_id="detail-posting-1", attempt_number=2,
        )
        coordinator.posting("posting-1", "terminally_skipped")
        finish(coordinator, "blocked", "E-FIXTURE-UNACCOUNTED")
        return coordinator.summary()

    coordinator.producer("detail-1", "detail_read", True, "success", "request-detail-1")
    coordinator.evaluated_job()
    coordinator.posting("posting-1", "evaluated")

    if scenario == "display_failure":
        coordinator.render_and_present(False)
        finish(coordinator, "blocked", "E-FIXTURE-DISPLAY")
        return coordinator.summary()

    if coordinator.trigger == "manual":
        coordinator.render_and_present(True)
        coordinator.phase("early_results_shown")
        coordinator.append("milestone", "early_results_shown")
        coordinator.effects.append("milestone:early_results_shown")
    else:
        coordinator.phase("early_results_shown")

    coordinator.phase("reviewing_remaining")

    if scenario == "remaining_work":
        finish(coordinator, "blocked", "E-FIXTURE-REMAINING")
        return coordinator.summary()

    coordinator.phase("finalizing")
    if scenario in ("artifact_write_failure", "artifact_validation_failure"):
        finish(coordinator, "blocked", "E-FIXTURE-ARTIFACT")
        return coordinator.summary()

    if scenario == "authority_window":
        if not coordinator.write_and_validate_artifacts("complete"):
            raise RuntimeError("intended complete artifacts did not validate")
        coordinator.intended_complete_files_existed_before_close = True
        coordinator.public_complete_authorized_before_close = coordinator.public_artifact_authority()
        coordinator.canary_authorized_before_close = coordinator.public_artifact_authority()
        readiness = coordinator.fold()
        if readiness["ready_to_close"] != "true":
            raise RuntimeError("authority-window fixture was not ready to close")
        coordinator.validated_before_complete_close = True
        coordinator.close("complete", "-")
        coordinator.public_complete_authorized_after_close = coordinator.public_artifact_authority()
        return coordinator.summary()

    finish(coordinator, "complete", "-")
    return coordinator.summary()


def main(argv):
    if len(argv) != 3:
        print("usage: fake-run-lifecycle SCENARIO WORKSPACE", file=sys.stderr)
        return 2
    scenario = argv[1]
    workspace = pathlib.Path(argv[2])
    if scenario not in VALID_SCENARIOS | REJECTED_SCENARIOS:
        print(json.dumps({"accepted": False, "effects": [], "error": "unknown_scenario"}))
        return 2

    trigger, scheduler_arg = ATTRIBUTION.get(scenario, ("manual", "-"))
    if scenario == "mutable_before_ledger" or not validate_attribution(trigger, scheduler_arg):
        print(json.dumps({"accepted": False, "effects": [], "error": "invalid_preflight"}))
        return 2

    try:
        summary = run_scenario(scenario, workspace)
    except (OSError, RuntimeError, ValueError) as exc:
        print(json.dumps({"accepted": True, "effects": [], "error": str(exc)}))
        return 1
    print(json.dumps(summary, sort_keys=True))
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv))
