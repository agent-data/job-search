#!/usr/bin/env python3
"""fake-agent-data — a PATH shim that mimics `agent-data` for tests. No network, no credits.

Scenario via env JOBSEARCH_TEST_SCENARIO (default "happy"); fixtures dir via JOBSEARCH_FIXTURES.
Scenarios: happy | many-promising | zero-empty | stretch | quota | bad-query | invalid-pair |
detail-fetch-failed | degraded | down | multi-source | one-source-down | source-unsupported |
legacy-source-swallow.
Error-injection scenarios reuse the "happy" fixtures (fallback) for any data they don't override.
Env JOBSEARCH_TEST_DOWN_SOURCE (default "ashby") selects which source one-source-down fails.
JOBSEARCH_TEST_NOAUTH=1 makes whoami report unauthenticated. `--version` answers (onboarding's
post-install check); `init` is NOT shimmed — evals stub it in the case prompt.
JOBSEARCH_TEST_RECENCY_SWALLOW=1 makes search-jobs ignore --published_on_or_after (no echo, no
filter) — a legacy server predating the recency param (mirrors legacy-source-swallow for --source).
"""
import json, os, re, sys

SCEN = os.environ.get("JOBSEARCH_TEST_SCENARIO", "happy")
FIX = os.environ.get("JOBSEARCH_FIXTURES", "")
SRC_ALLOWED = ("linkedin", "ashby", "greenhouse", "lever")


def out(obj):  # JSON to stdout, exit 0
    print(json.dumps(obj)); sys.exit(0)


def err(code, message, retryable, param=None, details=None):  # error envelope to stderr, exit 1
    body = {"code": code, "message": message, "retryable": retryable,
            "param": param, "request_id": "req_fake", "source": "fake"}
    if details is not None:
        body["details"] = details  # present on 422 validation_error; absent on other errors
    print(json.dumps({"error": body}), file=sys.stderr)
    sys.exit(1)


def flag(argv, name):  # value following --name in argv (e.g. --location), or None
    if name in argv:
        i = argv.index(name)
        if i + 1 < len(argv):
            return argv[i + 1]
    return None


def fixture(name, names=None):
    # Try each candidate filename in order, scenario dir first then "happy" (so error-injection
    # scenarios keep reusing happy's data). `names` lets a caller pass a per-source cascade.
    for fname in (names or [name]):
        for scen in (SCEN, "happy"):
            path = os.path.join(FIX, scen, fname)
            if os.path.exists(path):
                with open(path, encoding="utf-8") as f:
                    return json.load(f)
    err("fixture_not_found", f"no fixture {name!r} for scenario {SCEN!r} (no happy fallback)", False)


def main(argv):
    if not argv:
        err("usage", "no command", False)
    if argv[0] == "--version":
        print("0.0.0-fake")
        sys.exit(0)
    if argv[0] == "whoami":
        out({"api_key_set": os.environ.get("JOBSEARCH_TEST_NOAUTH") != "1",
             "api_key_source": "config", "base_url": "https://example.test"})
    if argv[0] == "call":
        slug = argv[2] if len(argv) > 2 else ""
        if slug == "status":
            if SCEN == "down":
                err("service_unreachable", "status route unreachable", False)
            out({"status": "degraded" if SCEN == "degraded" else "ok"})
        if slug == "search-jobs":
            src = flag(argv, "--source") or "linkedin"
            if SCEN == "legacy-source-swallow":
                out(fixture("search-jobs.json"))  # --source silently ignored; no echo injected
            if src not in SRC_ALLOWED or (SCEN == "source-unsupported" and src != "linkedin"):
                err("validation_error", f"Unsupported source {src!r} for source. Allowed values: linkedin, ashby, greenhouse, lever.", False, param="source")
            if SCEN == "one-source-down" and src == os.environ.get("JOBSEARCH_TEST_DOWN_SOURCE", "ashby"):
                err("upstream_unavailable", f"{src} search failed", True)
            if SCEN == "stretch":
                err("upstream_unavailable", "upstream fetch failed", True)
            if SCEN == "quota":
                err("quota_exceeded", "monthly API limit reached", False)
            if SCEN == "bad-query":
                loc = flag(argv, "--location")
                if loc and "INVALID" in loc.upper():
                    err("validation_error", f"location {loc!r} is not a recognized value", False,
                        param="location",
                        details=[{"loc": ["query", "location"], "msg": "unrecognized location",
                                  "type": "value_error"}])
            names = [f"search-jobs.{src}.json"] if src != "linkedin" else ["search-jobs.json"]
            fx = fixture("search-jobs.json", names=names)
            fx.setdefault("data", {}).setdefault("query", {})["source"] = src
            pub = flag(argv, "--published_on_or_after")
            if pub is not None:
                if not re.match(r"\d{4}-\d{2}-\d{2}", pub):  # non-ISO date → 422 (mirrors the live server)
                    err("validation_error", "Correct the request parameters and retry.", False,
                        param="published_on_or_after",
                        details=[{"loc": ["query", "published_on_or_after"],
                                  "msg": "invalid date", "type": "date_from_datetime_parsing"}])
                if os.environ.get("JOBSEARCH_TEST_RECENCY_SWALLOW") != "1":  # legacy server ignores it
                    cutoff = pub[:10]
                    fx["data"]["query"]["published_on_or_after"] = cutoff
                    def eff(row):  # effective date = later of published_at/posted_at present; else None
                        vals = [v for v in (row.get("published_at"), row.get("posted_at")) if v]
                        return max(vals)[:10] if vals else None
                    fx["data"]["results"] = [r for r in fx["data"]["results"]
                                             if eff(r) is not None and eff(r) >= cutoff]
            out(fx)
        if slug == "get-posting":
            if SCEN == "invalid-pair":
                err("validation_error", "posting_id/source_url mismatch", False, param="posting_id")
            if SCEN == "detail-fetch-failed":
                err("upstream_unavailable", "upstream detail fetch failed", True)
            src = flag(argv, "--source") or "linkedin"
            pid = flag(argv, "--posting_id") or ""
            if src != "linkedin":
                out(fixture("get-posting.json",
                            names=[f"get-posting.{src}.{pid}.json", f"get-posting.{src}.json"]))
            out(fixture("get-posting.json"))
    err("unsupported", f"unhandled args: {argv}", False)


if __name__ == "__main__":
    main(sys.argv[1:])
